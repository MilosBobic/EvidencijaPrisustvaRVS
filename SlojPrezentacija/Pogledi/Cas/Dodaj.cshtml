@model SlojPodataka.Modeli.Cas

<h2>Dodaj čas</h2>

<form method="post">

    <div>
        <label>Datum i vreme</label>
        <input asp-for="DatumVreme" type="datetime-local" />
    </div>

    <div>
        <label>Predmet</label>
        <select asp-for="PredmetId"
                asp-items="ViewBag.Predmeti">
        </select>
    </div>

    <button type="submit">
        Sačuvaj
    </button>

</form>