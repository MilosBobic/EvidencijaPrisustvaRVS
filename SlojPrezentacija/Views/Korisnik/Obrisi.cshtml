@model SlojPodataka.Modeli.Korisnik

<h2>Brisanje korisnika</h2>

<p>
    Da li želite da obrišete korisnika:
    <strong>
        @Model.KorisnickoIme
    </strong>
</p>

<form method="post">

    <input asp-for="Id" hidden />

    <button type="submit"
            class="btn btn-danger">
        Obrisi
    </button>

</form>