@model List<SlojPodataka.Modeli.Korisnik>

<h2>Korisnici</h2>

<p>
    <a asp-action="Dodaj">
        Dodaj korisnika
    </a>
</p>

<table class="table table-bordered">

    <tr>
        <th>Korisničko ime</th>
        <th>Uloga</th>
        <th>Akcije</th>
    </tr>

    @foreach (var k in Model)
    {
        <tr>
            <td>@k.KorisnickoIme</td>

            <td>@k.Uloga</td>

            <td>
                <a asp-action="Obrisi"
                   asp-route-id="@k.Id">
                    Obrisi
                </a>
            </td>
        </tr>
    }

</table>